# ---------------------------------------------------------------------------
# Site URL
# ---------------------------------------------------------------------------
# The canonical base URL used in sitemap.xml and robots.txt.
# Defaults to the production domain defined in src/lib/constants.ts (SITE.website).
#
# TODO (pre-launch): Set this to the final production domain in Vercel
# environment variables before submitting sitemap.xml to Google Search Console.
#
# For local development or Vercel preview testing you can override it here:
# NEXT_PUBLIC_SITE_URL=https://rohrkraft24.vercel.app
#
# For the final production build set:
# NEXT_PUBLIC_SITE_URL=https://rohrretter24.de
NEXT_PUBLIC_SITE_URL=https://rohrretter24.de

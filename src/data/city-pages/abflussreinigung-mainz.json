ms:flex-start;gap:0.875rem;\">\n              <span style=\"background:var(--orange);color:white;font-weight:800;font-size:0.8rem;width:24px;height:24px;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;\">2</span>\n              <span style=\"font-size:0.875rem;color:var(--gray-700);padding-top:2px;\">Mechanische Entstopfung mit Spirale</span>\n            </li>\n            <li style=\"display:flex;align-items:flex-start;gap:0.875rem;\">\n              <span style=\"background:var(--orange);color:white;font-weight:800;font-size:0.8rem;width:24px;height:24px;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;\">3</span>\n              <span style=\"font-size:0.875rem;color:var(--gray-700);padding-top:2px;\">Hochdruckspülung zur Restlos-Reinigung</span>\n            </li>\n            <li style=\"display:flex;align-items:flex-start;gap:0.875rem;\">\n              <span style=\"background:var(--orange);color:white;font-weight:800;font-size:0.8rem;width:24px;height:24px;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;\">4</span>\n              <span style=\"font-size:0.875rem;color:var(--gray-700);padding-top:2px;\">Sichtprüfung mit Kamera (auf Wunsch)</span>\n            </li>\n            <li style=\"display:flex;align-items:flex-start;gap:0.875rem;\">\n              <span style=\"background:var(--orange);color:white;font-weight:800;font-size:0.8rem;width:24px;height:24px;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;\">5</span>\n              <span style=\"font-size:0.875rem;color:var(--gray-700);padding-top:2px;\">Funktionstest und Protokoll</span>\n            </li>\n          </ol>\n        </div>\n        <div style=\"border:1px solid var(--gray-200);border-radius:var(--radius-xl);padding:1.5rem;\">\n          <p style=\"font-weight:700;color:var(--navy);margin-bottom:0.75rem;\">📍 Stadtteile Mainz</p>\n          <div style=\"display:flex;flex-wrap:wrap;gap:0.375rem;\">\n            <span style=\"background:var(--gray-100);color:var(--navy);font-size:0.8rem;font-weight:500;padding:0.2rem 0.625rem;border-radius:9999px;\">Altstadt</span><span style=\"background:var(--gray-100);color:var(--navy);font-size:0.8rem;font-weight:500;padding:0.2rem 0.625rem;border-radius:9999px;\">Neustadt</span><span style=\"background:var(--gray-100);color:var(--navy);font-size:0.8rem;font-weight:500;padding:0.2rem 0.625rem;border-radius:9999px;\">Gonsenheim</span><span style=\"background:var(--gray-100);color:var(--navy);font-size:0.8rem;font-weight:500;padding:0.2rem 0.625rem;border-radius:9999px;\">Hechtsheim</span><span style=\"background:var(--gray-100);color:var(--navy);font-size:0.8rem;font-weight:500;padding:0.2rem 0.625rem;border-radius:9999px;\">Mombach</span><span style=\"background:var(--gray-100);color:var(--navy);font-size:0.8rem;font-weight:500;padding:0.2rem 0.625rem;border-radius:9999px;\">Bretzenheim</span><span style=\"background:var(--gray-100);color:var(--navy);font-size:0.8rem;font-weight:500;padding:0.2rem 0.625rem;border-radius:9999px;\">Marienborn</span><span style=\"background:var(--gray-100);color:var(--navy);font-size:0.8rem;font-weight:500;padding:0.2rem 0.625rem;border-radius:9999px;\">Drais</span><span style=\"background:var(--gray-100);color:var(--navy);font-size:0.8rem;font-weight:500;padding:0.2rem 0.625rem;border-radius:9999px;\">Lerchenberg</span><span style=\"background:var(--gray-100);color:var(--navy);font-size:0.8rem;font-weight:500;padding:0.2rem 0.625rem;border-radius:9999px;\">Weisenau</span><span style=\"background:var(--gray-100);color:var(--navy);font-size:0.8rem;font-weight:500;padding:0.2rem 0.625rem;border-radius:9999px;\">Kostheim</span>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n<section class=\"section\" style=\"background:var(--gray-50);\">\n  <div class=\"container\">\n    <div class=\"grid-2-lg\" style=\"align-items:start;gap:3rem;\">\n      <div>\n        <p class=\"section-label\">Abflussreinigung Mainz</p>\n        <h2 class=\"section-title mb-4\">Abflussreinigung in Mainz – lokal verankert</h2>\n        <p style=\"color:var(--gray-700);line-height:1.75;margin-bottom:1rem;\">Mainz, die rheinland-pfälzische Landeshauptstadt direkt am Rhein, hat enge Verbindungen zum Rhein-Main-Gebiet und gehört zu unserem Kernservicegebiet. Vom historischen Dom-Viertel in der Altstadt bis zu den Neubauvierteln in Hechtsheim und Drais – Rohrkraft24 kennt die typischen Rohrsystemprobleme in Mainz und hilft schnell und fachgerecht.</p>\n        <p style=\"color:var(--gray-700);line-height:1.75;margin-bottom:1rem;\">Gonsenheim, Mombach, Bretzenheim, Lerchenberg – wir sind in allen Mainzer Stadtteilen vertreten. Besonders in der Mainzer Altstadt mit ihren teilweise jahrhundertealten Kanalstrukturen sind unsere Techniker speziell geschult.</p>\n        <p style=\"color:var(--gray-700);line-height:1.75;margin-bottom:1rem;\">Typische Gebäude vor Ort: Historische Altstadt-Bebauung, Jugendstilbauten in Gonsenheim, Plattenbausiedlungen, Neubaugebiete in Hechtsheim. Bei Abflussreinigung in Mainz sind wir dank über 70 betreuter Einsätze in der Region (Mainz und Rheinhessen) mit den örtlichen Rohr- und Kanalsystemen bestens vertraut – und in durchschnittlich 40–55 Minuten bei Ihnen, ob in Altstadt oder Neustadt.</p>\n        <p style=\"color:var(--gray-700);line-height:1.75;\">Wir sind im gesamten Stadtgebiet von Mainz im Einsatz – unter anderem in den Postleitzahlbereichen 55116, 55118, 55120, 55122, 55124, 55126, 55127, 55128, 55129, 55130, 55131.</p>\n      </div>\n      <div>\n        <div style=\"background:white;border:1px solid var(--gray-200);border-radius:1rem;padding:1.5rem;\">\n          <h3 style=\"font-size:1.05rem;font-weight:700;color:var(--navy);margin-bottom:1rem;\">Abflussreinigung in diesen Stadtteilen von Mainz</h3>\n          <div style=\"display:flex;flex-wrap:wrap;gap:0.5rem;\">\n            <span style=\"background:var(--gray-100);color:var(--navy);font-size:0.8125rem;font-weight:500;padding:0.25rem 0.75rem;border-radius:9999px;\">Altstadt</span><span style=\"background:var(--gray-100);color:var(--navy);font-size:0.8125rem;font-weight:500;padding:0.25rem 0.75rem;border-radius:9999px;\">Neustadt</span><span style=\"background:var(--gray-100);color:var(--navy);font-size:0.8125rem;font-weight:500;padding:0.25rem 0.75rem;border-radius:9999px;\">Gonsenheim</span><span style=\"background:var(--gray-100);color:var(--navy);font-size:0.8125rem;font-weight:500;padding:0.25rem 0.75rem;border-radius:9999px;\">Hechtsheim</span><span style=\"background:var(--gray-100);color:var(--navy);font-size:0.8125rem;font-weight:500;padding:0.25rem 0.75rem;border-radius:9999px;\">Mombach</span><span style=\"background:var(--gray-100);color:var(--navy);font-size:0.8125rem;font-weight:500;padding:0.25rem 0.75rem;border-radius:9999px;\">Bretzenheim</span><span style=\"background:var(--gray-100);color:var(--navy);font-size:0.8125rem;font-weight:500;padding:0.25rem 0.75rem;border-radius:9999px;\">Marienborn</span><span style=\"background:var(--gray-100);color:var(--navy);font-size:0.8125rem;font-weight:500;padding:0.25rem 0.75rem;border-radius:9999px;\">Drais</span><span style=\"background:var(--gray-100);color:var(--navy);font-size:0.8125rem;font-weight:500;padding:0.25rem 0.75rem;border-radius:9999px;\">Lerchenberg</span><span style=\"background:var(--gray-100);color:var(--navy);font-size:0.8125rem;font-weight:500;padding:0.25rem 0.75rem;border-radius:9999px;\">Weisenau</span><span style=\"background:var(--gray-100);color:var(--navy);font-size:0.8125rem;font-weight:500;padding:0.25rem 0.75rem;border-radius:9999px;\">Kostheim</span>\n          </div>\n          <p style=\"margin-top:1.25rem;color:var(--gray-600);font-size:0.9rem;line-height:1.6;\">Auch in allen weiteren Stadtteilen und Vororten von Mainz schnell für Sie da – rund um die Uhr.</p>\n        </di